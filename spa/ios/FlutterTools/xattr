#!/bin/sh

set -eu

REAL_XATTR="/usr/bin/xattr"

find_bundle_root() {
  target="$1"
  current="$target"

  while [ "$current" != "/" ] && [ "$current" != "." ]; do
    case "$current" in
      *.framework|*.bundle|*.appex|*.app)
        printf '%s\n' "$current"
        return 0
        ;;
    esac
    current="$(dirname "$current")"
  done

  return 1
}

if [ "$#" -ge 4 ] && [ "$1" = "-r" ] && [ "$2" = "-d" ] && [ "$3" = "com.apple.FinderInfo" ]; then
  target="$4"
  {
    printf 'xattr wrapper: %s\n' "$*"
    printf 'target: %s\n' "$target"
  } >> /tmp/spa_xattr_wrapper.log

  if bundle_root="$(find_bundle_root "$target")"; then
    printf 'bundle_root: %s\n' "$bundle_root" >> /tmp/spa_xattr_wrapper.log
    "$REAL_XATTR" -cr "$bundle_root" 2>/dev/null || true
  fi
fi

exec "$REAL_XATTR" "$@"
